# Copy to .env on the VPS and change secrets before first public launch.

COMPOSE_PROJECT_NAME=tls-audit

# Public app settings
PUBLIC_BASE_URL=https://tlslab.example.ru
TRUST_PROXY_HEADERS=true
API_BIND_HOST=127.0.0.1

# Scanner limits
MAX_SCAN_SECONDS=45
TESTSSL_TIMEOUT_SECONDS=45
TESTSSL_OPENSSL_TIMEOUT=5
RATE_LIMIT_PER_MINUTE=20
CAPTCHA_AFTER_PER_MINUTE=15
TARGET_COOLDOWN_SECONDS=30
ACTIVE_SCAN_TTL_SECONDS=900
MAX_QUEUE_DEPTH=50
# Comma-separated emergency denylist examples:
# BLOCKED_CLIENT_IPS=203.0.113.7,198.51.100.0/24
# BLOCKED_TARGETS=bad.example,*.noisy.example,bad.example:8443
BLOCKED_CLIENT_IPS=
BLOCKED_TARGETS=

# Docker egress firewall
DOCKER_EGRESS_NETWORK=tls-audit_default

# Data retention
REPORT_RETENTION_DAYS=30
ERROR_RETENTION_DAYS=7
BACKUP_DIR=/opt/tls-audit/backups
BACKUP_RETENTION_DAYS=14

# Healthcheck/monitoring
HEALTHCHECK_PUBLIC_URL=https://tlslab.example.ru
HEALTHCHECK_LOCAL_URL=http://127.0.0.1:8000/health
HEALTHCHECK_LOG_DIR=/opt/tls-audit/logs
DISK_WARN_PERCENT=85
CERT_WARN_DAYS=21
QUEUE_WARN_DEPTH=25
BACKUP_WARN_HOURS=30
# Optional SMTP email alerts. Leave empty to log only.
# Example SMTP_URL values:
# SMTP_URL=smtp://mail.example.ru:587
# SMTP_URL=smtps://mail.example.ru:465
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=info@tlsaudit.ru
SMTP_URL=
SMTP_USER=
SMTP_PASSWORD=

# Privacy-friendly server-side stats
STATS_DAYS=7
STATS_LOG_DIR=/opt/tls-audit/logs

# Internal services
POSTGRES_DB=tls_audit
POSTGRES_USER=tls_audit
POSTGRES_PASSWORD=change-me-long-random-password
DATABASE_URL=postgresql://tls_audit:change-me-long-random-password@postgres:5432/tls_audit
REDIS_URL=redis://redis:6379/0
